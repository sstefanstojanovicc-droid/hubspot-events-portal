generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Auth.js — extended with app roles and tenant binding.
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime? @map("email_verified")
  image           String?
  /// admin | client_user | client_admin (reserved)
  role            String    @default("client_user")
  clientAccountId String?   @map("client_account_id")
  /// invited | active | disabled
  status          String    @default("invited")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Singleton-style key/value (e.g. uploaded sidebar logo as data URL).
model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}

/// Pre-approved email for first Google sign-in (consumes on user creation).
model Invite {
  id              String    @id @default(cuid())
  email           String    @unique
  role            String
  clientAccountId String?   @map("client_account_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  consumedAt      DateTime? @map("consumed_at")

  @@map("invites")
}
