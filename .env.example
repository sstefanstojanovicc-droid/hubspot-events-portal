# Copy to .env.local for local development (never commit secrets).

# --- Auth.js (required) ---
# Set to true to skip Google login and use a fixed dev admin session (local only).
# In production, omit this or set AUTH_DISABLED=false.
AUTH_DISABLED=true
# Random string, e.g. `openssl rand -base64 32`
AUTH_SECRET=
# Google OAuth (Web application client). Callback: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# SQLite: path is relative to the prisma/ folder (same folder as schema.prisma).
DATABASE_URL="file:./dev.db"

# First admin (seed with: npm run db:seed — set emails first)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
# Optional: pre-approved Google email for a client user (invite consumed on first sign-in)
INITIAL_CLIENT_INVITE_EMAIL=
INITIAL_CLIENT_ACCOUNT_ID=

# Optional logo URL if not using uploaded logo (Branding page)
# NEXT_PUBLIC_ADMIN_LOGO_URL=

# --- HubSpot (server-only; required for API calls) ---
# Private app access token with CRM scopes. Set in Vercel → Settings → Environment Variables.
# Use a sandbox token for Preview if you want isolation from Production data.
HUBSPOT_ACCESS_TOKEN=

# --- Deployment URL (optional) ---
# Production: set to your custom domain, e.g. https://portal.example.com
# Preview: usually omit — Vercel sets VERCEL_URL automatically.
# Improves metadataBase / Open Graph when not using *.vercel.app as canonical.
# APP_URL=https://your-domain.com
