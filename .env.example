# Copy to .env.local for local development (never commit secrets).

# --- Auth.js (required) ---
# Skip Google: fixed admin session (middleware + auth()). Use on Vercel while demoing.
# Set any of: AUTH_DISABLED=true, OPEN_APP_LOGIN=true, DEMO_MODE=true. Remove before real OAuth.
AUTH_DISABLED=true
# OPEN_APP_LOGIN=true
# DEMO_MODE=true
# Random string, e.g. `openssl rand -base64 32` (32+ chars when OAuth is on). If bypass flags above are set,
# AUTH_SECRET can be omitted on Vercel — a demo placeholder is used until you enable real sign-in.
AUTH_SECRET=
# Google OAuth (Web application client). Callback: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# PostgreSQL (required for Vercel — use Neon, Supabase, or Vercel Postgres).
# Example Neon: postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# First admin (seed with: npm run db:seed — set emails first)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
# Optional: pre-approved Google email for a client user (invite consumed on first sign-in)
INITIAL_CLIENT_INVITE_EMAIL=
INITIAL_CLIENT_ACCOUNT_ID=

# Optional logo URL if not using uploaded logo (Branding page)
# NEXT_PUBLIC_ADMIN_LOGO_URL=

# --- HubSpot (server-only; required for API calls) ---
# Private app access token with CRM scopes. Set in Vercel → Settings → Environment Variables.
# Use a sandbox token for Preview if you want isolation from Production data.
HUBSPOT_ACCESS_TOKEN=

# --- Deployment URL (optional) ---
# Production: set to your custom domain, e.g. https://portal.example.com
# Preview: usually omit — Vercel sets VERCEL_URL automatically.
# Improves metadataBase / Open Graph when not using *.vercel.app as canonical.
# APP_URL=https://your-domain.com
#
# --- Vercel ---
# Required: DATABASE_URL = PostgreSQL (Neon / Vercel Postgres / Supabase). Build runs migrate + seed.
# Quick demo: DEMO_MODE / OPEN_APP_LOGIN / AUTH_DISABLED → no Google; /auth/signin redirects to /dashboard.
# Optional: AUTH_SECRET (32+ chars) and Google vars when you turn off demo flags.
# AUTH_SECRET is required at runtime for real sessions. The npm "build" script sets NEXT_PHASE so
# `next build` can finish in CI/Vercel even when AUTH_SECRET is only available at runtime — you should
# still add AUTH_SECRET to Vercel for Production (and Preview) so the live app can sign cookies.
# Google Cloud OAuth "Authorized redirect URI": https://YOUR_DOMAIN/api/auth/callback/google
